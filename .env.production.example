APP_NAME="Lucky Arcade Visual"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://arcade.example.com
APP_TIMEZONE=UTC
LOG_CHANNEL=stack
LOG_LEVEL=warning
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=lucky_arcade
DB_USERNAME=lucky_arcade
DB_PASSWORD=change-this-long-password
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=redis
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="Lucky Arcade Visual"
